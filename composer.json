{
    "name": "test-task/export-orders",
    "description": "Order import test task implemented with DDD, CQRS, and Hexagonal architecture.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "8.4.*",
        "webmozart/assert": "^1.11",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "ExportOrders\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ExportOrders\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "check": [
            "@test",
            "@analyse"
        ]
    }
}
